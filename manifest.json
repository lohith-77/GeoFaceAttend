  "shortcuts": [
    {
      "name": "Mark Attendance",
      "short_name": "Check In",
      "description": "Quickly mark your attendance with face verification",
      "url": "/employee/dashboard.html#attendance",
      "icons": [
        {
          "src": "assets/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Apply Leave",
      "short_name": "Leave",
      "description": "Apply for leave request",
      "url": "/employee/dashboard.html#leave",
      "icons": [
        {
          "src": "assets/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Admin Dashboard",
      "short_name": "Admin",
      "description": "Employee management and reports",
      "url": "/admin/dashboard.html",
      "icons": [
        {
          "src": "assets/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
