  "share_target": {
    "action": "/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "text/csv": [
          ".csv"
        ],
        "application/vnd.ms-excel": [
          ".xlsx"
        ]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "/handle-mail?to=%s"
    },
    {
      "protocol": "web+geoface",
      "url": "/handle-protocol?data=%s"
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://geofaceattend-api.onrender.com"
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://geofaceattend-1.onrender.com/manifest.json"
    }
  ]
}